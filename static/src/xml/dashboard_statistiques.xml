<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dashboard_analytics.DashboardStatistiques">
        <div class="o_action o_dashboard p-3">

            <!-- ═══════════════════════════════════════════
                 Bandeau filtre
            ═══════════════════════════════════════════ -->
            <div class="d-flex align-items-center gap-2 mb-4 flex-wrap"
                 style="background:linear-gradient(135deg,#f8f9fa,#eef0f3);
                        border-radius:14px; padding:14px 18px;
                        border:1px solid #dee2e6;
                        box-shadow:0 2px 8px rgba(0,0,0,.06);">

                <span style="font-weight:700; color:#333; font-size:14px; letter-spacing:.3px;">
                    📅 Période :
                </span>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Du</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px; border:1px solid #ccc;"
                           t-att-value="state.date_debut"
                           t-on-change="onDateDebutChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Au</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px; border:1px solid #ccc;"
                           t-att-value="state.date_fin"
                           t-on-change="onDateFinChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Zone</label>
                    <select class="form-select form-select-sm"
                            style="width:190px; border-radius:8px; border:1px solid #ccc;"
                            t-on-change="updateSelectedZone">
                        <option value="">Toutes les zones</option>
                        <t t-foreach="state.zones" t-as="zone" t-key="zone.id">
                            <option t-att-value="zone.id"
                                    t-att-selected="state.selected_zone == zone.id"
                                    t-esc="zone.name"/>
                        </t>
                    </select>
                </div>

                <button class="btn btn-sm btn-primary"
                        style="border-radius:8px; font-size:13px; padding:5px 14px;
                               background:linear-gradient(135deg,#1565c0,#6a1b9a);
                               border:none; box-shadow:0 2px 6px rgba(21,101,192,.4);"
                        t-on-click="appliquerFiltre"
                        t-att-disabled="state.loading">
                    <t t-if="state.loading">⏳ Chargement…</t>
                    <t t-else="">🔍 Appliquer</t>
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        style="border-radius:8px; font-size:13px; padding:5px 14px;"
                        t-on-click="reinitialiserMois"
                        t-att-disabled="state.loading">
                    🔄 Mois actuel
                </button>

                <span t-if="labelPeriode"
                      style="font-size:12px; color:#888; margin-left:4px; font-style:italic;">
                    (<t t-esc="labelPeriode"/>)
                </span>
            </div>

            <!-- ═══════════════════════════════════════════
                 Grille KPI  —  3 colonnes égales
            ═══════════════════════════════════════════ -->
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">

                <!-- ══════ LIGNE 1 ══════ -->

                <!-- 1. Réservations confirmées -->
                <div t-attf-style="border-radius:18px; border:none; cursor:pointer; color:#fff;
                            background: {{ !deltaReservations ? 'linear-gradient(135deg,#1565c0,#1e88e5)' : deltaReservations.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     t-on-click="ouvrirReservations"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">📋</div>
                        <div style="text-align:right;">
                            <div style="font-size:38px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="state.reservations_confirmer"/>
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Réservations Confirmées
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaReservations">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaReservations.positive">
                                        ▲ +<t t-esc="deltaReservations.val"/>
                                    </t>
                                    <t t-else="">
                                        ▼ <t t-esc="deltaReservations.val"/>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- 2. Chiffre d'affaires -->
                <div t-attf-style="border-radius:18px; border:none; cursor:pointer; color:#fff;
                            background: {{ !deltaCa ? 'linear-gradient(135deg,#2e7d32,#43a047)' : deltaCa.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">💶</div>
                        <div style="text-align:right;">
                            <div style="font-size:30px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="Math.round(state.total_ca_da)"/> DA
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Chiffre d'affaires
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaCa">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaCa.positive">▲ +<t t-esc="deltaCa.val"/> DA</t>
                                    <t t-else="">▼ <t t-esc="deltaCa.val"/> DA</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- 3. Trésorerie -->
                <div t-attf-style="border-radius:18px; border:none; color:#fff;
                            background: {{ !deltaTresorerie ? 'linear-gradient(135deg,#880e4f,#ad1457)' : deltaTresorerie.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">💰</div>
                        <div style="text-align:right;">
                            <div style="font-size:30px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="Math.round(state.total_tresorerie_da)"/> DA
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Trésorerie
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaTresorerie">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaTresorerie.positive">▲ +<t t-esc="deltaTresorerie.val"/> DA</t>
                                    <t t-else="">▼ <t t-esc="deltaTresorerie.val"/> DA</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- ══════ LIGNE 2 ══════ -->

                <!-- 4. Panier Moyen -->
                <div t-attf-style="border-radius:18px; border:none; cursor:pointer; color:#fff;
                            background: {{ !deltaPanier ? 'linear-gradient(135deg,#e65100,#fb8c00)' : deltaPanier.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">🛒</div>
                        <div style="text-align:right;">
                            <div style="font-size:30px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="Math.round(state.panier_moyen_da)"/> DA
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Panier Moyen
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaPanier">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaPanier.positive">▲ +<t t-esc="deltaPanier.val"/> DA</t>
                                    <t t-else="">▼ <t t-esc="deltaPanier.val"/> DA</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- 5. Dépenses  (logique inversée : baisse = vert, hausse = rouge) -->
                <div t-attf-style="border-radius:18px; border:none; cursor:pointer; color:#fff;
                            background: {{ !deltaDepense ? 'linear-gradient(135deg,#b71c1c,#ef5350)' : deltaDepense.positive ? 'linear-gradient(135deg,#c62828,#ef5350)' : 'linear-gradient(135deg,#2e7d32,#43a047)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     t-on-click="ouvrirDepenses"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">💸</div>
                        <div style="text-align:right;">
                            <div style="font-size:30px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="Math.round(state.total_depense_da)"/> DA
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Dépenses
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaDepense">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaDepense.positive">▲ +<t t-esc="deltaDepense.val"/> DA</t>
                                    <t t-else="">▼ <t t-esc="deltaDepense.val"/> DA</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- 6. Balance -->
                <div t-attf-style="border-radius:18px; border:none; color:#fff;
                            background: {{ !deltaBalance ? 'linear-gradient(135deg,#3949ab,#7986cb)' : deltaBalance.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">⚖️</div>
                        <div style="text-align:right;">
                            <div style="font-size:30px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="Math.round(balance)"/> DA
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9; margin-top:4px;">
                                Balance
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaBalance">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaBalance.positive">▲ +<t t-esc="deltaBalance.val"/> DA</t>
                                    <t t-else="">▼ <t t-esc="deltaBalance.val"/> DA</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- ══════ LIGNE 3 ══════ -->

                <!-- 7. Taux de remplissage -->
                <div t-attf-style="border-radius:18px; border:none; color:#fff;
                            background: {{ !deltaTaux ? 'linear-gradient(135deg,#00838f,#00acc1)' : deltaTaux.positive ? 'linear-gradient(135deg,#2e7d32,#43a047)' : 'linear-gradient(135deg,#c62828,#ef5350)' }};
                            box-shadow:0 6px 20px rgba(0,0,0,.3);
                            transition:transform .18s, box-shadow .18s;
                            grid-column: 1 / 2;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0,0,0,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 6px 20px rgba(0,0,0,.3)'">
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
                        <div style="font-size:52px; opacity:.95; line-height:1;">📊</div>
                        <div style="text-align:right; flex:1; margin-left:16px;">
                            <div style="font-size:34px; font-weight:900; letter-spacing:-1px; line-height:1;">
                                <t t-esc="state.taux_remplissage"/> %
                            </div>
                            <div style="background:rgba(255,255,255,.2); border-radius:10px;
                                        height:6px; margin:8px 0; overflow:hidden;">
                                <div t-attf-style="width:{{state.taux_remplissage}}%; height:100%;
                                                   background:#fff; border-radius:10px; transition:width .6s;"/>
                            </div>
                            <div style="font-size:13px; font-weight:600; opacity:.9;">
                                Taux de remplissage
                            </div>
                            <div style="font-size:11px; opacity:.65; margin-top:2px;">
                                <t t-esc="labelPeriode"/>
                            </div>
                            <t t-if="deltaTaux">
                                <div style="margin-top:8px; display:inline-block; padding:3px 12px;
                                            border-radius:20px; font-size:13px; font-weight:800;
                                            background:rgba(255,255,255,.85); color:#111;">
                                    <t t-if="deltaTaux.positive">▲ +<t t-esc="deltaTaux.val"/> %</t>
                                    <t t-else="">▼ <t t-esc="deltaTaux.val"/> %</t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

            </div><!-- fin grille -->
        </div>
    </t>
</templates>