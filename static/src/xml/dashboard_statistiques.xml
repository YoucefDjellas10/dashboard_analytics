<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dashboard_analytics.DashboardStatistiques">
        <div class="o_action o_dashboard p-3">

            <!-- ── Bandeau filtre dates ── -->
            <div class="d-flex align-items-center gap-2 mb-4 flex-wrap"
                 style="background:#f8f9fa; border-radius:12px; padding:12px 16px; border:1px solid #dee2e6;">

                <span style="font-weight:600; color:#444; font-size:14px;">📅 Période :</span>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Du</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px;"
                           t-att-value="state.date_debut"
                           t-on-change="onDateDebutChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Au</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px;"
                           t-att-value="state.date_fin"
                           t-on-change="onDateFinChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Zone</label>
                    <select class="form-select form-select-sm"
                            style="width:190px; border-radius:8px;"
                            t-on-change="updateSelectedZone">
                        <option value="">Toutes les zones</option>
                        <t t-foreach="state.zones" t-as="zone" t-key="zone.id">
                            <option t-att-value="zone.id"
                                    t-att-selected="state.selected_zone == zone.id"
                                    t-esc="zone.name"/>
                        </t>
                    </select>
                </div>

                <button class="btn btn-sm btn-primary"
                        style="border-radius:8px; font-size:13px;"
                        t-on-click="appliquerFiltre"
                        t-att-disabled="state.loading">
                    <t t-if="state.loading">⏳ Chargement…</t>
                    <t t-else="">🔍 Appliquer</t>
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        style="border-radius:8px; font-size:13px;"
                        t-on-click="reinitialiserMois"
                        t-att-disabled="state.loading">
                    🔄 Mois actuel
                </button>

                <span t-if="labelPeriode"
                      style="font-size:12px; color:#888; margin-left:4px;">
                    (<t t-esc="labelPeriode"/>)
                </span>
            </div>

            <!-- ── Cartes KPI ── -->
            <div class="d-flex flex-wrap gap-3">

                <!-- Réservations confirmées -->
                <div class="card"
                     style="width:180px; cursor:pointer; background-color:#e8d5d5;
                            border:none; border-radius:12px;
                            transition:transform .15s, box-shadow .15s;"
                     t-on-click="ouvrirReservations"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">📋</div>
                        <div style="font-size:32px; font-weight:bold; color:#333;">
                            <t t-esc="state.reservations_confirmer"/>
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Réservations Confirmées</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Chiffre d'affaires -->
                <div class="card"
                     style="width:180px; cursor:pointer; background-color:#d5e8d5;
                            border:none; border-radius:12px;
                            transition:transform .15s, box-shadow .15s;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">💶</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="Math.round(state.total_ca_da)"/> DA
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Chiffre d'affaires</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Trésorerie -->
                <div class="card"
                     style="width:180px; cursor:pointer; background-color:#d5d5e8;
                            border:none; border-radius:12px;
                            transition:transform .15s, box-shadow .15s;"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">💰</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="Math.round(state.total_tresorerie_da)"/> DA
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Trésorerie</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Panier Moyen -->
                <div class="card"
                     style="width:180px; cursor:pointer; background-color:#fde8c8;
                            border:none; border-radius:12px;
                            transition:transform .15s, box-shadow .15s;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">🛒</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="Math.round(state.panier_moyen_da)"/> DA
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Panier Moyen</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Dépenses -->
                <div class="card"
                     style="width:180px; cursor:pointer; background-color:#e8d5d5;
                            border:none; border-radius:12px;
                            transition:transform .15s, box-shadow .15s;"
                     t-on-click="ouvrirDepenses"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">💸</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="Math.round(state.total_depense_da)"/> DA
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Dépenses</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Balance -->
                <div class="card"
                     t-attf-style="background-color: {{ balance >= 0 ? '#d5e8d5' : '#e8d5d5' }}; width:180px; cursor:pointer; border:none; border-radius:12px; transition:transform .15s, box-shadow .15s;"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">⚖️</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="Math.round(balance)"/> DA
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Balance</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

                <!-- Taux de remplissage -->
                <div class="card"
                     t-attf-style="background-color: {{ state.taux_remplissage >= 80 ? '#d5e8d5' : state.taux_remplissage >= 40 ? '#fde8c8' : '#e8d5d5' }}; width:180px; border:none; border-radius:12px; transition:transform .15s, box-shadow .15s;"
                     onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 18px rgba(0,0,0,.12)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body text-center p-3">
                        <div style="font-size:40px;">📊</div>
                        <div style="font-size:28px; font-weight:bold; color:#333;">
                            <t t-esc="state.taux_remplissage"/> %
                        </div>
                        <div style="font-size:13px; color:#555; margin-top:4px;">Taux de remplissage</div>
                        <div style="font-size:11px; color:#888; margin-top:2px;"><t t-esc="labelPeriode"/></div>
                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>