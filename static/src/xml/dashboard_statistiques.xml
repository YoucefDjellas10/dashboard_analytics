<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dashboard_analytics.DashboardStatistiques">
        <div class="o_action o_dashboard p-3">

            <!-- ═══════════════════════════════════════════
                 Bandeau filtre
            ═══════════════════════════════════════════ -->
            <div class="d-flex align-items-center gap-2 mb-4 flex-wrap"
                 style="background:linear-gradient(135deg,#f8f9fa,#eef0f3);
                        border-radius:14px; padding:14px 18px;
                        border:1px solid #dee2e6;
                        box-shadow:0 2px 8px rgba(0,0,0,.06);">

                <span style="font-weight:700; color:#333; font-size:14px; letter-spacing:.3px;">
                    📅 Période :
                </span>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Du</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px; border:1px solid #ccc;"
                           t-att-value="state.date_debut"
                           t-on-change="onDateDebutChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Au</label>
                    <input type="date"
                           class="form-control form-control-sm"
                           style="width:145px; border-radius:8px; border:1px solid #ccc;"
                           t-att-value="state.date_fin"
                           t-on-change="onDateFinChange"/>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <label style="font-size:12px; color:#666; white-space:nowrap;">Zone</label>
                    <select class="form-select form-select-sm"
                            style="width:190px; border-radius:8px; border:1px solid #ccc;"
                            t-on-change="updateSelectedZone">
                        <option value="">Toutes les zones</option>
                        <t t-foreach="state.zones" t-as="zone" t-key="zone.id">
                            <option t-att-value="zone.id"
                                    t-att-selected="state.selected_zone == zone.id"
                                    t-esc="zone.name"/>
                        </t>
                    </select>
                </div>

                <button class="btn btn-sm btn-primary"
                        style="border-radius:8px; font-size:13px; padding:5px 14px;
                               background:linear-gradient(135deg,#4776e6,#8e54e9);
                               border:none; box-shadow:0 2px 6px rgba(71,118,230,.4);"
                        t-on-click="appliquerFiltre"
                        t-att-disabled="state.loading">
                    <t t-if="state.loading">⏳ Chargement…</t>
                    <t t-else="">🔍 Appliquer</t>
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        style="border-radius:8px; font-size:13px; padding:5px 14px;"
                        t-on-click="reinitialiserMois"
                        t-att-disabled="state.loading">
                    🔄 Mois actuel
                </button>

                <span t-if="labelPeriode"
                      style="font-size:12px; color:#888; margin-left:4px; font-style:italic;">
                    (<t t-esc="labelPeriode"/>)
                </span>
            </div>

            <!-- ═══════════════════════════════════════════
                 Helper interne : badge delta
                 (réutilisé dans chaque carte via t-call)
            ═══════════════════════════════════════════ -->

            <!-- ═══════════════════════════════════════════
                 Cartes KPI
            ═══════════════════════════════════════════ -->
            <div class="d-flex flex-wrap gap-3">

                <!-- ── 1. Réservations confirmées ── -->
                <div class="card"
                     style="width:190px; cursor:pointer; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#1a73e8,#6c63ff);
                            box-shadow:0 4px 15px rgba(26,115,232,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     t-on-click="ouvrirReservations"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(26,115,232,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(26,115,232,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">📋</div>
                        <div style="font-size:34px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="state.reservations_confirmer"/>
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500;">
                            Réservations Confirmées
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <!-- Delta N-1 -->
                        <t t-if="deltaReservations">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaReservations.positive">
                                    <span style="color:#00e676;">▲ +<t t-esc="deltaReservations.val"/></span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaReservations.val"/></span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 2. Chiffre d'affaires ── -->
                <div class="card"
                     style="width:190px; cursor:pointer; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#11998e,#38ef7d);
                            box-shadow:0 4px 15px rgba(17,153,142,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(17,153,142,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(17,153,142,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">💶</div>
                        <div style="font-size:26px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="Math.round(state.total_ca_da)"/> DA
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500;">
                            Chiffre d'affaires
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaCa">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaCa.positive">
                                    <span style="color:#00e676;">▲ +<t t-esc="deltaCa.val"/> DA</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaCa.val"/> DA</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 3. Trésorerie ── -->
                <div class="card"
                     style="width:190px; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#f953c6,#b91d73);
                            box-shadow:0 4px 15px rgba(249,83,198,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(249,83,198,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(249,83,198,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">💰</div>
                        <div style="font-size:26px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="Math.round(state.total_tresorerie_da)"/> DA
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500;">
                            Trésorerie
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaTresorerie">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaTresorerie.positive">
                                    <span style="color:#00e676;">▲ +<t t-esc="deltaTresorerie.val"/> DA</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaTresorerie.val"/> DA</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 4. Panier Moyen ── -->
                <div class="card"
                     style="width:190px; cursor:pointer; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#f7971e,#ffd200);
                            box-shadow:0 4px 15px rgba(247,151,30,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     t-on-click="ouvrirChiffreAffaire"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(247,151,30,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(247,151,30,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">🛒</div>
                        <div style="font-size:26px; font-weight:800; letter-spacing:-1px; color:#4a3200;">
                            <t t-esc="Math.round(state.panier_moyen_da)"/> DA
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500; color:#4a3200;">
                            Panier Moyen
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px; color:#4a3200;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaPanier">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.12);">
                                <t t-if="deltaPanier.positive">
                                    <span style="color:#1b5e20;">▲ +<t t-esc="deltaPanier.val"/> DA</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaPanier.val"/> DA</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 5. Dépenses ── -->
                <div class="card"
                     style="width:190px; cursor:pointer; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#f85032,#e73827);
                            box-shadow:0 4px 15px rgba(248,80,50,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     t-on-click="ouvrirDepenses"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(248,80,50,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(248,80,50,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">💸</div>
                        <div style="font-size:26px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="Math.round(state.total_depense_da)"/> DA
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500;">
                            Dépenses
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaDepense">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaDepense.positive">
                                    <span style="color:#b71c1c;">▲ +<t t-esc="deltaDepense.val"/> DA</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#00e676;">▼ <t t-esc="deltaDepense.val"/> DA</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 6. Balance ── -->
                <div class="card"
                     style="width:190px; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#4776e6,#8e54e9);
                            box-shadow:0 4px 15px rgba(71,118,230,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(71,118,230,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(71,118,230,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">⚖️</div>
                        <div style="font-size:26px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="Math.round(balance)"/> DA
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:3px; font-weight:500;">
                            Balance
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaBalance">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaBalance.positive">
                                    <span style="color:#00e676;">▲ +<t t-esc="deltaBalance.val"/> DA</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaBalance.val"/> DA</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── 7. Taux de remplissage ── -->
                <div class="card"
                     style="width:190px; border:none; border-radius:16px;
                            background:linear-gradient(135deg,#0f9b8e,#00d2ff);
                            box-shadow:0 4px 15px rgba(0,210,255,.35);
                            transition:transform .18s, box-shadow .18s; color:#fff;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,210,255,.45)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(0,210,255,.35)'">
                    <div class="card-body text-center p-3">
                        <div style="font-size:36px; opacity:.9;">📊</div>
                        <div style="font-size:30px; font-weight:800; letter-spacing:-1px;">
                            <t t-esc="state.taux_remplissage"/> %
                        </div>
                        <!-- Barre de progression -->
                        <div style="background:rgba(255,255,255,.25); border-radius:10px;
                                    height:5px; margin:6px 0; overflow:hidden;">
                            <div t-attf-style="width:{{state.taux_remplissage}}%; height:100%;
                                               background:#fff; border-radius:10px; transition:width .5s;"/>
                        </div>
                        <div style="font-size:12px; opacity:.85; margin-top:2px; font-weight:500;">
                            Taux de remplissage
                        </div>
                        <div style="font-size:11px; opacity:.7; margin-top:2px;">
                            <t t-esc="labelPeriode"/>
                        </div>
                        <t t-if="deltaTaux">
                            <div style="margin-top:8px; display:inline-block;
                                        padding:2px 10px; border-radius:20px;
                                        font-size:13px; font-weight:800;
                                        background:rgba(0,0,0,.18);">
                                <t t-if="deltaTaux.positive">
                                    <span style="color:#00e676;">▲ +<t t-esc="deltaTaux.val"/> %</span>
                                </t>
                                <t t-else="">
                                    <span style="color:#b71c1c;">▼ <t t-esc="deltaTaux.val"/> %</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>